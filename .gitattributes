# Default: auto-detect text files, normalize to LF in the repo AND working tree.
# This overrides core.autocrlf and eliminates LF<->CRLF conversion warnings.
* text=auto eol=lf

# --- Text sources (force LF) ---
*.py     text eol=lf
*.sql    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.csv    text eol=lf
*.toml   text eol=lf
*.ini    text eol=lf
*.cfg    text eol=lf
*.sh     text eol=lf
*.env*   text eol=lf

# --- Git metadata ---
.gitignore     text eol=lf
.gitattributes text eol=lf

# --- Windows-only scripts (keep CRLF) ---
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# --- Binary (never normalize) ---
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.bmp   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.xlsx  binary
*.xls   binary
*.db    binary
*.sqlite   binary
*.sqlite3  binary
*.pyc   binary
