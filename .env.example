# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# Feishu / Lark notification webhook
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Feishu App credentials (for doc/sheet API)
LARK_APP_ID=
LARK_APP_SECRET=

# Feishu default target resources (optional, auto-created if empty)
LARK_DOC_ID=
LARK_SHEET_TOKEN=
LARK_SHEET_ID=
LARK_BITABLE_TOKEN=

# QuestDB connection
QDB_HOST=127.0.0.1
QDB_PORT=8812
QDB_USER=admin
QDB_PASSWORD=your-password
QDB_DBNAME=qdb

# TongDaXin data path
TQCENTER_PATH=K:\txdlianghua\PYPlugins\sys
